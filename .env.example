# Copy to `.env` and fill in real values for local dev. Production loads
# the same keys via systemd EnvironmentFile.

# sqlite path. For local dev, a relative path is fine; in production this is
# an absolute path under /opt/goodgirls-registry/data/.
DATABASE_URL=sqlite:./registry.db

# SHA-256 hex of the operator's chosen admin key.
# Generate with: echo -n "your-admin-key" | sha256sum
ADMIN_KEY_HASH=replace-with-sha256-hex

BASE_DOMAIN=goodgirls.onl
LISTEN_ADDR=127.0.0.1:3001

# Honeypot login page path (D6). Anything non-obvious works.
DECOY_PATH=/gg
